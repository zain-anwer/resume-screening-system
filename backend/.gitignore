# ==================================================
# Python
# ==================================================

__pycache__/
*.py[cod]
*$py.class

*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv/

# Package builds
build/
dist/
*.egg-info/
.eggs/


# ==================================================
# Environment & Secrets
# ==================================================

.env
.env.*
!.env.example

*.key
*.pem
*.crt


# ==================================================
# Candidate Data (SENSITIVE - NEVER COMMIT)
# ==================================================

# Raw resumes
data/resumes_raw/

# Supporting documents
data/supporting_docs/

# Processed candidate information
data/processed_json/

# Annotation data
data/annotations/

# Any extracted personal information
**/*cnic*
**/*degree*
**/*identity*
**/*personal*


# ==================================================
# ML Models & Embeddings
# ==================================================

# Downloaded/generated models
models/embeddings/
models/rerankers/

# Model weights
*.bin
*.pt
*.pth
*.onnx
*.safetensors

# Vector databases / indexes
*.faiss
*.index
*.pkl
*.pickle


# ==================================================
# Generated Outputs
# ==================================================

output/json/
output/csv/
output/excel/
output/pdf/


# ==================================================
# Logs
# ==================================================

logs/*
!logs/.gitkeep

*.log


# ==================================================
# Reports & Evaluation Results
# ==================================================

reports/evaluation_results/
reports/screenshots/


# ==================================================
# Jupyter Notebook
# ==================================================

.ipynb_checkpoints/

# Notebook generated files
*.nbconvert.ipynb


# ==================================================
# Streamlit
# ==================================================

.streamlit/

# Streamlit cache
.streamlit/cache/


